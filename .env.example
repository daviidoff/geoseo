# =============================================================================
# GEOSEO - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in the values
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE - Database & Authentication [REQUIRED]
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# GOOGLE GEMINI AI [REQUIRED for AI features]
# Get this from: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# PYTHON BACKEND [REQUIRED for keyword/blog/mentions/health generation]
# The unified mono-python-service backend
# Local: http://localhost:8000
# Production: Deploy backend/ directory to your hosting service
# -----------------------------------------------------------------------------
PYTHON_BACKEND_URL=http://localhost:8000

# Legacy Railway URLs (deprecated - use PYTHON_BACKEND_URL instead)
# RAILWAY_OPENKEYWORD_URL=https://openkeyword-service-production.up.railway.app
# RAILWAY_OPENCONTEXT_URL=https://opencontext-service-production.up.railway.app
# RAILWAY_OPENBLOG_URL=https://openblog-service-production.up.railway.app

# -----------------------------------------------------------------------------
# SERPER - SERP Analysis [OPTIONAL - for keyword SERP analysis]
# Get this from: https://serper.dev
# -----------------------------------------------------------------------------
SERPER_API_KEY=your-serper-api-key

# -----------------------------------------------------------------------------
# SE RANKING - Competitor Analysis [OPTIONAL - for competitor gap analysis]
# Get this from: https://seranking.com
# -----------------------------------------------------------------------------
SE_RANKING_API_KEY=your-seranking-api-key

# -----------------------------------------------------------------------------
# MODAL.COM - Batch Processing [OPTIONAL - for bulk CSV processing]
# Get these from: https://modal.com/settings
# -----------------------------------------------------------------------------
MODAL_API_URL=https://scaile--g-mcp-tools-v2-api.modal.run/bulk/generic
MODAL_WEBHOOK_SECRET=your-modal-webhook-secret

# -----------------------------------------------------------------------------
# STRIPE - Payments [OPTIONAL - only needed if testing payments]
# Get these from: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
STRIPE_METER_ID=mtr_...
STRIPE_METERED_PRICE_ID=price_...
STRIPE_METER_EVENT_NAME=usage_recorded
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# APPLICATION CONFIG [OPTIONAL]
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Development mode - bypasses credit checks (set to 'true' for local dev)
NEXT_PUBLIC_DEV_MODE=true

# -----------------------------------------------------------------------------
# MONITORING [OPTIONAL - for production]
# -----------------------------------------------------------------------------
# Sentry - Error tracking (https://sentry.io)
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog - Analytics (https://posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# SECURITY [REQUIRED in production]
# -----------------------------------------------------------------------------
CRON_SECRET=your-random-secret-for-cron-jobs

# -----------------------------------------------------------------------------
# FEATURE FLAGS [OPTIONAL]
# -----------------------------------------------------------------------------
NEXT_PUBLIC_USE_NEW_FILE_UPLOAD=false
NEXT_PUBLIC_USE_NEW_CSV_PARSER=false
NEXT_PUBLIC_USE_NEW_BATCH_PROCESSOR=false
NEXT_PUBLIC_USE_SERVICE_LAYER=false
NEXT_PUBLIC_USE_ZUSTAND_STORE=false
NEXT_PUBLIC_USE_COMPRESSED_UI=false

# -----------------------------------------------------------------------------
# RESEND - Transactional Emails [OPTIONAL - required for waitlist emails]
# Get this from: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# WAITLIST MODE [OPTIONAL]
# Set to 'true' to enable waitlist mode - all CTAs will open a signup modal
# Set to 'false' or omit to enable normal auth flow
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WAITLIST_MODE=false
